{
  "expo": {
    "name": "Pallavi",
    "slug": "pallavi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#5B2A86"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pallavi.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Pallavi needs camera access to scan QR codes."
      }
    },
    "android": {
      "package": "com.pallavi.app",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#5B2A86"
      },
      "permissions": ["CAMERA"]
    },
    "web": {
      "favicon": "./src/assets/icon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Pallavi to access your camera to scan QR codes."
        }
      ]
    ]
  }
}
